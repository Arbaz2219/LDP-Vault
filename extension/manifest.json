{
  "manifest_version": 3,
  "name": "LDP Logistics Vault",
  "version": "1.0",
  "description": "Securely autofill your credentials from LDP Logistics Vault.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:5000/*",
    "<all_urls>"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
