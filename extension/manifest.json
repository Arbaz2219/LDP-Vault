{
  "manifest_version": 3,
  "name": "LDP Antigravity Vault",
  "version": "1.1.0",
  "description": "Enterprise Secure Auto-Login for LDP Logistics.",
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "webNavigation",
    "activeTab"
  ],
  "host_permissions": [
    "https://api-vault.ldplogistics.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_icon": "icon.png"
  },
  "icons": {
    "128": "icon.png"
  }
}
